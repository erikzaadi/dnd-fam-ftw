[Unit]
Description=Family DND FTW Backend
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/var/www/dnd-fam-ftw
ExecStart=/usr/bin/node --env-file=.env backend/dist/index.js
Restart=on-failure
Environment=NODE_ENV=production
Environment=PORT=3001

[Install]
WantedBy=multi-user.target
