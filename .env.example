# Persistence
PERSISTENCE_PROVIDER=sqlite
SQLITE_DB_PATH=./data/dnd-fam-ftw.sqlite

# Image storage
IMAGE_STORAGE_PROVIDER=local
LOCAL_IMAGE_STORAGE_PATH=./data/generated-images
LOCAL_IMAGE_PUBLIC_BASE_URL=/api/generated

# S3 image storage (only needed when IMAGE_STORAGE_PROVIDER=s3)
# AWS_REGION=eu-west-1
# S3_IMAGE_BUCKET=fam-dnd-ftw-images
# S3_IMAGE_PREFIX=generated/
# S3_IMAGE_PUBLIC_BASE_URL=https://images.fam-dnd-ftw.erikzaadi.com

# Frontend build vars (set these in CI/CD environment or .env.production for AWS builds)
# VITE_BASE_PATH=/                                          # '/' for AWS (root domain), '/dnd-fam-ftw/' for local deployment
# VITE_API_BASE_URL=https://api.fam-dnd-ftw.erikzaadi.com  # backend origin for cross-domain; leave unset for local dev

# AI providers
AI_NARRATION_PROVIDER=openai
AI_IMAGE_PROVIDER=openai
OPENAI_API_KEY=

# LocalAI (optional)
# LOCALAI_BASE_URL=http://localhost:8080
# LOCALAI_NARRATION_MODEL=qwen3-1.7b
# LOCALAI_IMAGE_BASE_URL=http://localhost:8080
# LOCALAI_IMAGE_MODEL=sd-3.5-large-ggml
# LOCALAI_IMAGE_STEPS=8

# Auth
# SESSION_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
