# Copy to scripts/deploy/.env.deploy and fill in. Never commit this file.
# These are sourced by all deploy scripts. Most values come from terraform outputs.
# Run: cd terraform && terraform output -json  to get them.

# Instance SSH host (static IP from terraform output: lightsail_static_ip)
LIGHTSAIL_HOST=

# AWS CLI profile to use for S3/CloudFront/SSM operations
AWS_PROFILE=dnd-fam-ftw-terraform

# From terraform output
AWS_REGION=eu-west-1
SSM_PREFIX=/dnd-fam-ftw/prod
FRONTEND_BUCKET=            # terraform output: frontend_bucket_name
CF_DIST_ID=                 # terraform output: cloudfront_distribution_id
API_DOMAIN=                 # terraform output: api_url (strip https://)
FRONTEND_DOMAIN=            # terraform output: frontend_url (strip https://)
IMAGE_BUCKET_URL=           # terraform output: image_bucket_url
IMAGE_BUCKET_NAME=          # terraform output: image_bucket_name
