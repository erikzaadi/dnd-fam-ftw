{
    "name": "dnd-fam-ftw",
    "version": "1.0.0",
  "type": "module",
    "scripts": {
        "dev:backend": "npm run dev --prefix backend",
        "dev:frontend": "npm run dev --prefix frontend -- --host",
        "dev": "npm run dev:backend & npm run dev:frontend",
        "build": "npm run build --prefix frontend",
        "build:backend": "npm run build --prefix backend",
        "install:all": "npm install --prefix backend && npm install --prefix frontend",
        "setup:lint": "python3 -m venv .venv-lint && .venv-lint/bin/pip install --quiet yamllint",
        "lint:workflows": "actionlint && .venv-lint/bin/yamllint .github/workflows/ && shellcheck -x --severity=warning scripts/**/*.sh scripts/deploy/*.sh"
    }
}
